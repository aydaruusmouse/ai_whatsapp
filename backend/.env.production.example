# Production server — copy to backend/.env (one entry per variable, no duplicates)
#   cp .env.production.example .env
#   nano .env

# LLM — OpenRouter (recommended)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-PASTE_YOUR_KEY_HERE
